{
  "expo": {
    "name": "Clear Care Dental",
    "slug": "clear-care-dental",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B4F72"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearcaredentalgroup.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4F72"
      },
      "package": "com.clearcaredentalgroup.app"
    },
    "extra": {
      "apiUrl": "https://api.clearcaredentalgroup.com/api/v1"
    }
  }
}
