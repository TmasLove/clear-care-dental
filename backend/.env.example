# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/clearcaredental

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3001

# App URL (used for magic links and invite URLs)
APP_URL=http://localhost:3001

# Email (nodemailer – for production use)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@clearcaredental.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Clear Care Dental <noreply@clearcaredental.com>"
